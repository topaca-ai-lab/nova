{
	"name": "@nova-ai/nova-mom",
	"version": "0.69.0",
	"description": "Slack bot that delegates messages to the nova coding agent",
	"type": "module",
	"bin": {
		"mom": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.16",
		"@nova-ai/nova-agent-core": "^0.69.0",
		"@nova-ai/nova-ai": "^0.69.0",
		"@nova-ai/nova-coding-agent": "^0.69.0",
		"typebox": "^1.1.24",
		"@slack/socket-mode": "^2.0.0",
		"@slack/web-api": "^7.0.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3"
	},
	"keywords": [
		"slack",
		"bot",
		"ai",
		"agent"
	],
	"author": "TOPACA AI-Lab (Markus Ertel) <hello@topaca.com>",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/topaca-ai-lab/nova.git",
		"directory": "packages/mom"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"bugs": {
		"url": "https://github.com/topaca-ai-lab/nova/issues",
		"email": "hello@topaca.com"
	},
	"homepage": "https://github.com/topaca-ai-lab/nova"
}
